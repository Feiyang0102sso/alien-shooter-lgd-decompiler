// ======================
// 正常函数
// ======================
normal1()
{
    int a = 1;
    int b = 2;
    int c = a + b;
}

// ======================
// 纯空函数
// ======================
empty1()
{
}

// ======================
// 只有 return
// ======================
ret1()
{
    return;
}

// ======================
// 多个空函数连续
// ======================
empty2()
{
}

empty3()
{
}

empty4()
{
}

// ======================
// 多个 return 函数连续
// ======================
ret2()
{
    return;
}

ret3()
{
    return;
}

ret4()
{
    return;
}

// ======================
// 正常函数夹在空函数之间
// ======================
empty5()
{
}

normal2()
{
    int x = 10;
    int y = 20;
    int z = x + y;
}

empty6()
{
}

// ======================
// return 函数夹在正常函数之间
// ======================
normal3()
{
    int a = 5;
}

ret5()
{
    return;
}

normal4()
{
    int b = 6;
}

// ======================
// 单行空函数
// ======================
empty7(){}

// ======================
// 单行 return 函数
// ======================
ret6(){return;}

// ======================
// 单行正常函数
// ======================
normal5(){int a = 1;}

// ======================
// 大量空函数连续（极端测试）
// ======================
e1(){}
e2(){}
e3(){}
e4(){}
e5(){}
e6(){}
e7(){}
e8(){}
e9(){}
e10(){}

// ======================
// 正常函数结尾
// ======================
normal6()
{
    int m = 100;
    int n = 200;
    int k = m + n;
}