.lgd_sample/
*.asm
*.lgd
*.lgc
*.csv
*.c

# --- allow test data ---
!tests/**/data/
!tests/**/data/*.lgd
!tests/**/data/*.csv
!tests/**/data/*.asm
!tests/**/data/LGC/*.lgc



