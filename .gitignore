# --- IDE configuration file ---
.idea/

# --- Python cached files (standard ignore) ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# --- pyproject ---
*.egg-info/

# --- environment ---
.venv/

# --- LOGS ---
*.log
